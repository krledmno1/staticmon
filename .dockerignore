# Keep the docker build context small and free of host build artifacts.
.git
.DS_Store
**/.DS_Store
builddir
builddir_debug
profile
CMakeUserPresets.json
# host-side experiment outputs
experiments/runner/dist-newstyle
# per-formula generated headers (the image generates its own); keep the
# committed formula.h includer, which the template monitor needs at compile time
src/staticmon/input_formula/formula_in.h
src/staticmon/input_formula/formula_csts.h
